{
  "$schema": "https://docs.openclaw.ai/schema/config.json",
  "gateway": {
    "channels": {
      "discord": {
        "token": "${DISCORD_BOT_TOKEN}",
        "allowedGuilds": ["${DISCORD_SERVER_ID}"],
        "allowedChannels": [
          "${DISCORD_CHANNEL_TASKS}",
          "${DISCORD_CHANNEL_STATUS}"
        ]
      }
    },
    "pairing": {
      "allowedUsers": ["${DISCORD_USER_ID}"]
    }
  },
  "providers": {
    "moonshot": {
      "baseUrl": "https://api.moonshot.cn/v1",
      "apiKey": "${MOONSHOT_API_KEY}",
      "api": "openai-completions"
    },
    "openrouter": {
      "baseUrl": "https://openrouter.ai/api/v1",
      "apiKey": "${OPENROUTER_API_KEY}",
      "api": "openai-completions"
    },
    "ollama": {
      "baseUrl": "${OLLAMA_HOST:-http://localhost:11434}/v1",
      "apiKey": "ollama",
      "api": "openai-completions"
    }
  },
  "agents": {
    "task-router": {
      "description": "Orchestrator: decomposes high-level goals into atomic Vikunja tasks for generic builder agents. Handles /status, /decompose, /wiki, /deploy commands.",
      "model": "moonshot/kimi-k2.5",
      "provider": "moonshot",
      "fallbackProviders": ["openrouter"],
      "systemPromptFile": "./task-router-prompt.md",
      "builtinTools": [],
      "bindings": [
        {
          "channel": "discord",
          "channelFilter": ["${DISCORD_CHANNEL_TASKS}", "${DISCORD_CHANNEL_STATUS}"]
        }
      ],
      "tools": {
        "mcp": {
          "axinova-tools": {
            "include": [
              "vikunja_list_projects",
              "vikunja_list_tasks",
              "vikunja_get_task",
              "vikunja_create_task",
              "vikunja_create_tasks",
              "vikunja_update_task",
              "vikunja_update_tasks",
              "vikunja_delete_task",
              "vikunja_list_labels",
              "vikunja_add_task_label",
              "vikunja_add_task_labels",
              "vikunja_remove_task_label"
            ]
          }
        }
      },
      "maxTurns": 8,
      "temperature": 0.2
    }
  }
}
